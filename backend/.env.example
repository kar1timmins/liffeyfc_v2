# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Application Environment
APP_ENV=development

# Enable API logging (1 = enabled, 0 = disabled)
ENABLE_API_LOGS=1

# reCAPTCHA Configuration (v3 - if backend handles verification)
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# Web3Forms Configuration (if backend handles form submissions)
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Database Configuration (if needed in future)
# DATABASE_URL=your_database_url_here

# CORS Configuration (if needed)
# CORS_ORIGIN=http://localhost:5173

# JWT Configuration (REQUIRED for authentication)
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters required for security
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_RANDOM_SECRET_WITH_THE_COMMAND_ABOVE
JWT_EXPIRES_IN=15m

# Wallet Encryption Configuration (REQUIRED for wallet generation)
# Generate a 64-character hex key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key is used to encrypt private keys and mnemonics in the database
WALLET_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_64_CHAR_HEX_KEY_WITH_THE_COMMAND_ABOVE

# GCP Storage Configuration (for profile photos and file uploads)
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_BUCKET_NAME=your_gcp_bucket_name_here
# For local development, specify the key file path:
GCP_KEY_FILENAME=lfc_key_gcp_bucket.json
# For production, use Application Default Credentials (ADC) and leave GCP_KEY_FILENAME empty

# SMTP Configuration (Zoho Mail for email sending)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=info@liffeyfoundersclub.com
SMTP_PASS=your_app_specific_password_here

# Frontend URL (for password reset links in emails)
FRONTEND_URL=http://localhost:5173
# For production, set to your deployed frontend URL (e.g., https://liffeyfoundersclub.com)