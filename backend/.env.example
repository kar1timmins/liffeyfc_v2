# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
APP_ENV=development

# Enable API logging (1 = enabled, 0 = disabled)
ENABLE_API_LOGS=1

# ============================================
# reCAPTCHA Configuration (v3 - if backend handles verification)
# ============================================
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# ============================================
# Web3Forms Configuration (if backend handles form submissions)
# ============================================
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# Option 1: Use DATABASE_URL (recommended for production)
# Format: postgres://username:password@host:port/database
# Example: postgres://lfc_user:lfc_password@localhost:5432/lfc_db
DATABASE_URL=postgres://lfc_user:lfc_pass@postgres:5432/lfc_db

# Option 2: Use individual database variables (recommended for development)
# For docker-compose: use 'postgres' as hostname (service name in docker network)
# For local development: use 'localhost' instead
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lfc_user
POSTGRES_PASSWORD=lfc_pass
POSTGRES_DB=lfc_db

# Auto-sync schema from entities in development
# Set to FALSE in production and use migrations instead
TYPEORM_SYNCHRONIZE=true

# ============================================
# JWT Configuration
# ============================================
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters required for security
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_RANDOM_SECRET_WITH_THE_COMMAND_ABOVE
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_A_SECURE_RANDOM_REFRESH_SECRET_WITH_THE_COMMAND_ABOVE
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Web3 & Wallet Configuration
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts user wallets and sensitive cryptographic data
# MUST be 64 hex characters (32 bytes)
WALLET_ENCRYPTION_KEY=88478f11364a7758ef2d6069a7dcdbabf4232f6b395786c50d82a4d3086c3274

# Optional: Private key for deploying contracts (development only)
# NEVER commit this to version control in production
WEB3_PRIVATE_KEY=

# ============================================
# Ethereum Sepolia Configuration (Testnet)
# ============================================
# Primary RPC endpoint for Ethereum Sepolia
# The service will automatically fallback to alternative endpoints if primary fails
# Free/Public options:
#   - https://sepolia.drpc.org
#   - https://sepolia-rpc.publicnode.com
#   - https://ethereum-sepolia.publicnode.com
#   - https://sepolia.infura.io/v3/9aa3d95b3bc440fa88ea12eaa4456161
#   - https://rpc.sepolia.org (may be rate-limited)
# Paid/Dedicated options (recommended for production):
#   - Infura: https://sepolia.infura.io/v3/<YOUR_INFURA_KEY>
#   - Alchemy: https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
#   - QuickNode: https://weathered-aged-frog.ethereum-sepolia.quiknode.pro/<YOUR_TOKEN>/
# Fallback endpoints are hardcoded in EscrowContractService for reliability
ETHEREUM_RPC_URL=https://sepolia.drpc.org

# Ethereum Sepolia Factory contract address (required for deployments)
# Deployed during: cd hardhat && npx hardhat run scripts/deploy-factory.ts --network sepolia
ETHEREUM_FACTORY_ADDRESS=0x

# ============================================
# Avalanche Fuji Configuration (Testnet)
# ============================================
# Primary RPC endpoint for Avalanche Fuji testnet
# Free/Public options:
#   - https://api.avax-test.network/ext/bc/C/rpc (official)
#   - https://avalanche-fuji-c-chain.publicnode.com
#   - https://avalanche-fuji.drpc.org
# Paid/Dedicated options (recommended for production):
#   - QuickNode: https://ava-fuji.quiknode.pro/<YOUR_TOKEN>/ext/bc/C/rpc
# Fallback endpoints are hardcoded in EscrowContractService for reliability
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Avalanche Fuji Factory contract address (required for deployments)
# Deployed during: cd hardhat && npx hardhat run scripts/deploy-factory.ts --network fuji
AVALANCHE_FACTORY_ADDRESS=0x

# ============================================
# Redis Configuration (for distributed nonce management)
# ============================================
# For docker-compose: use 'redis' as hostname (service name in docker network)
# For local development: use 'localhost' or '127.0.0.1'
REDIS_URL=redis://redis:6379

# ============================================
# GCP Configuration (for profile photos)
# ============================================
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_BUCKET_NAME=your_gcp_bucket_name_here
GCP_KEY_FILENAME=lfc_key_gcp_bucket.json

# ============================================
# Email Configuration (for transactional emails)
# ============================================
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@liffeyfoundersclub.com
FRONTEND_URL=http://localhost:5173# Alternative: Port 587 with STARTTLS (if 465 is blocked)

# Frontend URL (for password reset links in emails)
FRONTEND_URL=http://localhost:5173
# For production, set to your deployed frontend URL (e.g., https://liffeyfoundersclub.com)