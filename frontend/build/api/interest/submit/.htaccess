# Enable PHP execution and proper routing for API endpoint
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Ensure PHP files are processed
    DirectoryIndex index.php
    
    # Handle POST requests to this directory
    RewriteCond %{REQUEST_METHOD} ^POST$
    RewriteRule ^$ index.php [L]
</IfModule>

# Set environment variables (replace with your actual keys)
# You MUST update these values with your real keys from your .env file
SetEnv RECAPTCHA_SECRET_KEY "6LfLPNorAAAAAP0MpC3rtovBY6fuG8-HGue14ae8"
SetEnv WEB3FORMS_ACCESS_KEY "e9fac31f-2f01-42fd-b0e6-0faab7148fe5"

# Ensure PHP is executed
<Files "index.php">
    <IfModule mod_php.c>
        php_flag engine on
    </IfModule>
</Files>

# Set proper headers for API responses
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "POST, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type"
    Header always set Content-Type "application/json; charset=utf-8"
</IfModule>