# Apache configuration for SvelteKit static build on Blacknight
# Ensure UTF-8
AddDefaultCharset utf-8

# MIME types for JavaScript modules and other assets
<IfModule mod_mime.c>
  # JavaScript modules
  AddType application/javascript .js
  AddType application/javascript .mjs
  AddType text/javascript .js
  
  # CSS
  AddType text/css .css
  
  # JSON
  AddType application/json .json
  
  # SVG
  AddType image/svg+xml .svg
  
  # Web fonts
  AddType font/woff .woff
  AddType font/woff2 .woff2
  AddType application/font-woff .woff
  AddType application/font-woff2 .woff2
  
  # Video formats
  AddType video/webm .webm
  AddType video/mp4 .mp4
  
  # Compressed files
  AddType application/gzip .gz
  AddType application/x-brotli .br
  
  # Manifest
  AddType application/manifest+json .webmanifest
</IfModule>

# Compression (if not handled globally)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# SvelteKit specific: Ensure JS files are served with correct MIME types
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs)$">
    Header set Content-Type "application/javascript"
  </FilesMatch>
</IfModule>

# Cache static assets (fingerprinted by Vite)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

# Force HTTPS (optional – uncomment if SSL cert is active)
#<IfModule mod_rewrite.c>
#RewriteEngine On
#RewriteCond %{HTTPS} !=on
#RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
#</IfModule>

# Single Page App fallback: serve index.html for all non-file requests
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Explicitly serve files from _app directory (most important - must be first)
  RewriteCond %{REQUEST_URI} ^/_app/
  RewriteRule ^ - [L]
  
  # Allow static asset directories
  RewriteCond %{REQUEST_URI} ^/(img|videos|api)/
  RewriteRule ^ - [L]
  
  # Allow files with specific extensions
  RewriteCond %{REQUEST_URI} \.(js|mjs|css|json|svg|png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|webm|mp4|br|gz|txt|xml|webmanifest)$
  RewriteRule ^ - [L]
  
  # Allow existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Everything else goes to index.html for SPA routing
  RewriteRule ^ /index.html [L]
</IfModule>

# Security headers (tweak as needed)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-XSS-Protection "1; mode=block"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Updated CSP for Railway email server
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com; connect-src 'self' https://liffeyfcform-production.up.railway.app https://www.google.com https://www.google.com/recaptcha/ https://www.gstatic.com; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; frame-src https://www.google.com/recaptcha/;"
</IfModule>

# Disable directory listings
Options -Indexes
