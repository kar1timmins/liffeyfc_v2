# Client-side (public) env vars must be prefixed with PUBLIC_
# reCAPTCHA v3 site key (invisible verification)
PUBLIC_RECAPTCHA_SITE_KEY=

# Server-side (configure in hosting control panel or SetEnv in .htaccess)
# reCAPTCHA v3 secret key
RECAPTCHA_SECRET_KEY=
WEB3FORMS_ACCESS_KEY=
# or legacy
WEB_ACCESS_KEY=
