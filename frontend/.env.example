# Frontend Environment Variables Template
# Copy this file to .env.local for development
# Set these values in your hosting platform for production

# ============================================
# PUBLIC VARIABLES (exposed to browser)
# Must be prefixed with PUBLIC_ for SvelteKit
# ============================================

# reCAPTCHA v3 site key (get from Google reCAPTCHA console)
PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Debug logging (1 = enabled, 0 = disabled)
PUBLIC_DEBUG_LOGS=1

# Application Environment (development, staging, production)
PUBLIC_APP_ENV=development

# Backend API URL
# Development: http://localhost:3000
# Production: https://liffeyfcv2-production.up.railway.app
PUBLIC_API_URL=http://localhost:3000

# API endpoint for form submissions
PUBLIC_FORM_API_URL=/api/interest/submit/

# ============================================
# SERVER-SIDE VARIABLES (not exposed to browser)
# Do NOT prefix with PUBLIC_
# ============================================

# reCAPTCHA v3 secret key (server-side only)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Web3Forms access key (if using)
WEB3FORMS_ACCESS_KEY=your_web3forms_key_here

# Legacy support
WEB_ACCESS_KEY=your_web3forms_key_here

# Resend API Key (for email sending)
RESEND_API_KEY=your_resend_api_key_here

