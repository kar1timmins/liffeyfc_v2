# ── Redis ──────────────────────────────────────────────────────────────────────
# Same Redis instance used by NestJS and BullMQ.
# On Railway: use the internal private URL from the Redis service.
REDIS_URL=redis://localhost:6379

# ── Platform wallet ────────────────────────────────────────────────────────────
# The EVM address (same key on both chains) that users send USDC to.
# Both Sepolia and Fuji use the same derived address.
PLATFORM_RECEIVER_ADDRESS=0xYourPlatformTreasuryAddressHere

# Minimum USDC raw amount to recognise as a valid x402 payment (6 decimal places).
# Default is 10 USDC = 10_000_000.
USDC_REQUIRED_RAW_AMOUNT=10000000

# ── Ethereum Sepolia ────────────────────────────────────────────────────────────
# Obtain a WebSocket URL from Alchemy, QuickNode, or Infura.
# Example: wss://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
RPC_WSS_ETH_SEPOLIA=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# USDC proxy contract on Sepolia (official Circle testnet address).
USDC_ADDRESS_ETH_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# EscrowFactory contract address (deploy with: cd hardhat && npx hardhat run scripts/deploy-factory.ts --network sepolia)
ETHEREUM_FACTORY_ADDRESS=0xYourSepoliaFactoryAddress

# ── Avalanche Fuji ─────────────────────────────────────────────────────────────
# Example: wss://avax-fuji.g.alchemy.com/v2/YOUR_API_KEY
# Or the public endpoint: wss://api.avax-test.network/ext/bc/C/ws
RPC_WSS_AVAX_FUJI=wss://api.avax-test.network/ext/bc/C/ws

# USDC contract on Fuji (official Circle testnet address).
USDC_ADDRESS_AVAX_FUJI=0x5425890298aed601595a70AB815c96711a31Bc65

# EscrowFactory contract on Fuji (deploy with: --network fuji)
AVALANCHE_FACTORY_ADDRESS=0xYourFujiFactoryAddress

# ── Solana (optional) ──────────────────────────────────────────────────────────
# Leave blank to disable Solana monitoring entirely.

# WebSocket endpoint for Solana (devnet or mainnet-beta).
# Example devnet: wss://api.devnet.solana.com
# Example Helius: wss://devnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_WSS_SOLANA=

# HTTP RPC for fetching full transaction details (used alongside WS).
RPC_HTTP_SOLANA=https://api.devnet.solana.com

# USDC SPL token mint on Solana devnet.
# Devnet:  Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_MINT=

# Platform wallet public key (base58). Must have a USDC ATA already created.
SOLANA_PLATFORM_WALLET=

# ── Health check ───────────────────────────────────────────────────────────────
# HTTP port for the /health and /ready endpoints (Railway uses this).
PORT=8080

# ── Bitcoin (mempool.space WebSocket) ─────────────────────────────────────────
# Leave blank to disable Bitcoin monitoring entirely.
BITCOIN_PLATFORM_ADDRESS=

# Bitcoin network: "mainnet" or "testnet4" (default: mainnet).
# mainnet  → wss://mempool.space/api/v1/ws
# testnet4 → wss://mempool.space/testnet4/api/v1/ws
BITCOIN_NETWORK=mainnet

# ── Stellar (Horizon SSE) ──────────────────────────────────────────────────────
# Leave blank to disable Stellar monitoring entirely.
STELLAR_PLATFORM_ADDRESS=

# Horizon URL. Testnet: https://horizon-testnet.stellar.org
# Mainnet:  https://horizon.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
