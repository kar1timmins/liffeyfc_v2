# Root Environment Variables Template
# Copy this file to .env and fill in your actual values

# Application Environment
APP_ENV=development

# Enable API logging (1 = enabled, 0 = disabled)
ENABLE_API_LOGS=1

# reCAPTCHA Configuration (v3 - invisible)
# Get these from https://www.google.com/recaptcha/admin
PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# Web3Forms Configuration
# Get this from https://web3forms.com/
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Development URLs (used by docker-compose)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000